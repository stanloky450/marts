NEXT_PUBLIC_API_URL=/api/v1
API_PROXY_TARGET_URL=http://localhost:5700/api/v1
LEGACY_API_BASE_URL=http://localhost:5700/api/v1

# Preferred production option: point the Next.js proxy at your Appwrite HTTP gateway.
# Example:
# APPWRITE_API_GATEWAY_URL=https://api.example.com/api/v1

# Fallback option: let Next.js call the Appwrite function execution API directly.
# These variables are server-side only. Do not expose them as NEXT_PUBLIC_ values.
# APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
# APPWRITE_PROJECT_ID=your_appwrite_project_id
# APPWRITE_API_KEY=your_server_api_key
# APPWRITE_FUNCTION_ID=gateway-function
